# ─── AWS ───────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=your-etl-bucket-name

# ─── Snowflake ─────────────────────────────────────────────────────────────────
# Account format: <org_name>-<account_name>  (from Snowflake URL)
SNOWFLAKE_ACCOUNT=your_account_identifier
SNOWFLAKE_USER=your_snowflake_username
SNOWFLAKE_PASSWORD=your_snowflake_password
SNOWFLAKE_DATABASE=ECOMMERCE_DW
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=SYSADMIN

# ─── APIs ──────────────────────────────────────────────────────────────────────
# Open Exchange Rates — sign up free at https://openexchangerates.org/
OPEN_EXCHANGE_RATES_APP_ID=your_app_id_here
# Fake Store API & REST Countries require NO key — leave these blank
